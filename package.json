{
  "name": "flavor-factory-app",
  "version": "1.0.0",
  "description": "E-commerce mobile app for Flavor Factory",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace FlavorFactory.xcworkspace -scheme FlavorFactory -configuration Release"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/stack": "^6.3.0",
    "react-native-screens": "^3.22.0",
    "react-native-safe-area-context": "^4.6.0",
    "react-native-gesture-handler": "^2.12.0",
    "redux": "^4.2.1",
    "react-redux": "^8.1.0",
    "redux-thunk": "^2.4.2",
    "axios": "^1.4.0",
    "react-native-vector-icons": "^10.0.0",
    "react-native-fs": "^2.20.0",
    "@react-native-async-storage/async-storage": "^1.17.11"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "typescript": "^5.0.0",
    "jest": "^29.6.0",
    "@testing-library/react-native": "^12.1.0",
    "eslint": "^8.44.0",
    "@typescript-eslint/parser": "^5.61.0",
    "@typescript-eslint/eslint-plugin": "^5.61.0"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json", "node"]
  }
}
